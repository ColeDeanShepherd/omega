@page "/ai-context"
@inject IApiClient ApiClient

<PageTitle>AI Context</PageTitle>

<h1>AI Context</h1>

<p class="text-muted">
    Edit the shared markdown context used for AI task delegation.
</p>

@if (isLoading)
{
    <p><em>Loading...</em></p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-warning" role="alert">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success" role="alert">
            @successMessage
        </div>
    }

    <textarea class="form-control ai-context-textarea"
              @bind="aiContextContent"
              @bind:event="oninput"
              disabled="@isSaving"
              aria-label="AI context markdown editor"></textarea>

    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary"
                type="button"
                disabled="@isSaving"
                @onclick="HandleSaveAsync">
            @if (isSaving)
            {
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            }
            else
            {
                <span>Save</span>
            }
        </button>

        <button class="btn btn-outline-secondary"
                type="button"
                disabled="@isSaving"
                @onclick="LoadAiContextAsync">
            Reload
        </button>
    </div>
}

@code {
    private string aiContextContent = string.Empty;
    private bool isLoading = true;
    private bool isSaving;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAiContextAsync();
    }

    private async Task LoadAiContextAsync()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        var result = await ApiClient.GetAiContextAsync();

        isLoading = false;

        if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
        {
            errorMessage = result.ErrorMessage;
            return;
        }

        aiContextContent = result.Content;
    }

    private async Task HandleSaveAsync()
    {
        isSaving = true;
        errorMessage = null;
        successMessage = null;

        var result = await ApiClient.SaveAiContextAsync(aiContextContent);

        isSaving = false;

        if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
        {
            errorMessage = result.ErrorMessage;
            return;
        }

        aiContextContent = result.Content;
        successMessage = "AI context saved.";
    }
}