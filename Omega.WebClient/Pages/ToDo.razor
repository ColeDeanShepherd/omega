@page "/"
@inject IApiClient ApiClient

<PageTitle>To-Do</PageTitle>

<h1>To-Do</h1>

<form class="row g-2 mb-3" @onsubmit="HandleAddTodoAsync" @onsubmit:preventDefault="true">
	<div class="col-md-9">
		<input class="form-control" @bind="newTodoTitle" placeholder="Add a new to-do" />
	</div>
	<div class="col-md-3">
		<button class="btn btn-primary w-100" type="submit" disabled="@isSubmittingTodo">
			@(isSubmittingTodo ? "Adding..." : "Add")
		</button>
	</div>
</form>

@if (!string.IsNullOrWhiteSpace(addTodoErrorMessage))
{
	<div class="alert alert-warning" role="alert">
		@addTodoErrorMessage
	</div>
}

@if (!string.IsNullOrWhiteSpace(toggleTodoErrorMessage))
{
	<div class="alert alert-warning" role="alert">
		@toggleTodoErrorMessage
	</div>
}

@if (isLoading)
{
	<p><em>Loading...</em></p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
	<div class="alert alert-danger" role="alert">
		@errorMessage
	</div>
}
else if (todos is { Count: > 0 })
{
	<ul class="list-group">
		@foreach (var todo in todos)
		{
			<li class="list-group-item d-flex justify-content-between align-items-center">
				<div class="d-flex align-items-center gap-2">
					<span>@todo.Title</span>
					<span class="badge @(todo.IsComplete ? "text-bg-success" : "text-bg-secondary")">
						@(todo.IsComplete ? "Done" : "Open")
					</span>
				</div>
				<button class="btn btn-sm btn-outline-primary"
						type="button"
						disabled="@(isSubmittingTodo || togglingTodoIds.Contains(todo.Id))"
						@onclick="() => HandleToggleTodoAsync(todo)">
					@(togglingTodoIds.Contains(todo.Id)
						? "Saving..."
						: (todo.IsComplete ? "Mark Open" : "Mark Done"))
				</button>
			</li>
		}
	</ul>
}
else
{
	<p>No to-do items were returned by the API.</p>
}

@code {
	private IReadOnlyList<TodoItem>? todos;
	private bool isLoading = true;
	private string? errorMessage;
	private string newTodoTitle = string.Empty;
	private bool isSubmittingTodo;
	private string? addTodoErrorMessage;
	private string? toggleTodoErrorMessage;
	private HashSet<int> togglingTodoIds = [];

	protected override async Task OnInitializedAsync()
	{
		await LoadTodosAsync();
	}

	private async Task HandleAddTodoAsync()
	{
		addTodoErrorMessage = null;
		toggleTodoErrorMessage = null;

		var title = newTodoTitle.Trim();

		if (string.IsNullOrWhiteSpace(title))
		{
			addTodoErrorMessage = "Enter a title before adding a to-do item.";
			return;
		}

		isSubmittingTodo = true;
		var addResult = await ApiClient.AddTodoAsync(title);
		isSubmittingTodo = false;

		if (!string.IsNullOrWhiteSpace(addResult.ErrorMessage))
		{
			addTodoErrorMessage = addResult.ErrorMessage;
			return;
		}

		newTodoTitle = string.Empty;
		await LoadTodosAsync();
	}

	private async Task HandleToggleTodoAsync(TodoItem todo)
	{
		toggleTodoErrorMessage = null;
		togglingTodoIds.Add(todo.Id);

		var result = await ApiClient.SetTodoCompletionAsync(todo.Id, !todo.IsComplete);

		togglingTodoIds.Remove(todo.Id);

		if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
		{
			toggleTodoErrorMessage = result.ErrorMessage;
			return;
		}

		await LoadTodosAsync();
	}

	private async Task LoadTodosAsync()
	{
		isLoading = true;
		var result = await ApiClient.GetTodosAsync();
		todos = result.Todos;
		errorMessage = result.ErrorMessage;
		isLoading = false;
	}
}
