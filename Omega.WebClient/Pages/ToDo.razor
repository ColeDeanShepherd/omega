@page "/"
@inject IApiClient ApiClient

<PageTitle>To-Do</PageTitle>

<h1>To-Do</h1>

<form class="row g-2 mb-3" @onsubmit="HandleAddTodoAsync" @onsubmit:preventDefault="true">
	<div class="col-md-7">
		<input class="form-control" @bind="newTodoTitle" placeholder="@GetAddTodoPlaceholder()" />
	</div>
	<div class="col-md-3">
		<select class="form-select"
				@bind="selectedAddTodoKind"
				disabled="@isSubmittingTodo"
				aria-label="Select what to add">
			<option value="@AddTodoKind.StandardTodo">Add a todo</option>
			<option value="@AddTodoKind.ChangeOmega">Change Omega</option>
		</select>
	</div>
	<div class="col-md-2">
		<button class="btn btn-primary" type="submit" disabled="@isSubmittingTodo" aria-label="Add">
			@if (isSubmittingTodo)
			{
				<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
			}
			else
			{
				<i class="bi bi-plus-lg" aria-hidden="true"></i>
			}
		</button>
	</div>
</form>

@if (!string.IsNullOrWhiteSpace(addTodoErrorMessage))
{
	<div class="alert alert-warning" role="alert">
		@addTodoErrorMessage
	</div>
}

@if (!string.IsNullOrWhiteSpace(toggleTodoErrorMessage))
{
	<div class="alert alert-warning" role="alert">
		@toggleTodoErrorMessage
	</div>
}

@if (!string.IsNullOrWhiteSpace(deleteTodoErrorMessage))
{
	<div class="alert alert-warning" role="alert">
		@deleteTodoErrorMessage
	</div>
}

@if (!string.IsNullOrWhiteSpace(updateTodoErrorMessage))
{
	<div class="alert alert-warning" role="alert">
		@updateTodoErrorMessage
	</div>
}

@if (!string.IsNullOrWhiteSpace(moveTodoErrorMessage))
{
	<div class="alert alert-warning" role="alert">
		@moveTodoErrorMessage
	</div>
}

@if (!string.IsNullOrWhiteSpace(delegateTodoErrorMessage))
{
	<div class="alert alert-warning" role="alert">
		@delegateTodoErrorMessage
	</div>
}

@if (!string.IsNullOrWhiteSpace(delegateTodoSuccessMessage))
{
	<div class="alert alert-success" role="alert">
		@delegateTodoSuccessMessage
	</div>
}

@if (isLoading)
{
	<p><em>Loading...</em></p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
	<div class="alert alert-danger" role="alert">
		@errorMessage
	</div>
}
else if (todos is { Count: > 0 })
{
	@if (activeTodoEntries.Count > 0)
	{
		@RenderTodoList(activeTodoEntries)
	}
	else
	{
		<p>No active top-level to-do items.</p>
	}

	@if (completedTopLevelTodoGroups.Count > 0)
	{
		<h2 class="h4 mt-4">Completed</h2>

		@foreach (var group in completedTopLevelTodoGroups)
		{
			<h3 class="h6 mt-3 mb-2">@GetCompletedGroupHeading(group.LocalCompletionDate)</h3>
			@RenderTodoList(group.Entries)
		}
	}
}
else
{
	<p>No to-do items were returned by the API.</p>
}

@if (pendingDeleteTodo is not null)
{
	<div class="modal show d-block" tabindex="-1" aria-modal="true" role="dialog">
		<div class="modal-dialog">
			<div class="modal-content">
				<div class="modal-header">
					<h5 class="modal-title">Delete "@pendingDeleteTodo.Title"?</h5>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
					@if (pendingDeleteTodo.Children.Count > 0)
					{
						<button type="button" class="btn btn-danger" @onclick="() => ConfirmDeleteAsync(false)">Delete this and children</button>
						<button type="button" class="btn btn-warning" @onclick="() => ConfirmDeleteAsync(true)">Delete this and move children up</button>
					}
					else
					{
						<button type="button" class="btn btn-danger" @onclick="() => ConfirmDeleteAsync(false)">Delete</button>
					}
				</div>
			</div>
		</div>
	</div>
	<div class="modal-backdrop show" @onclick="CancelDelete"></div>
}

@code {
	private IReadOnlyList<TodoItem>? todos;
	private bool isLoading = true;
	private string? errorMessage;
	private string newTodoTitle = string.Empty;
	private bool isSubmittingTodo;
	private string? addTodoErrorMessage;
	private string? toggleTodoErrorMessage;
	private string? deleteTodoErrorMessage;
	private string? updateTodoErrorMessage;
	private string? moveTodoErrorMessage;
	private string? delegateTodoErrorMessage;
	private string? delegateTodoSuccessMessage;
	private AddTodoKind selectedAddTodoKind = AddTodoKind.StandardTodo;
	private HashSet<int> togglingTodoIds = [];
	private HashSet<int> deletingTodoIds = [];
	private HashSet<int> movingTodoIds = [];
	private HashSet<int> delegatingTodoIds = [];
	private IReadOnlyList<TodoListEntry> todoEntries = [];
	private IReadOnlyList<TodoListEntry> activeTodoEntries = [];
	private IReadOnlyList<CompletedTopLevelTodoGroup> completedTopLevelTodoGroups = [];
	private TodoItem? pendingDeleteTodo;
	private int? editingTodoId;
	private string editingTodoTitle = string.Empty;
	private int? addingChildParentId;
	private string addingChildTitle = string.Empty;
	private static readonly IReadOnlyList<string> ChangeOmegaChildTodoTitles =
	[
		"plan",
		"create Git branch",
		"modify code",
		"build & test code",
		"review modifications",
		"commit & push",
		"open PR",
		"assign reviewers",
		"review loop",
		"complete PR"
	];

	protected override async Task OnInitializedAsync()
	{
		await LoadTodosAsync();
	}

	private async Task HandleAddTodoAsync()
	{
		addTodoErrorMessage = null;
		toggleTodoErrorMessage = null;
		deleteTodoErrorMessage = null;
		moveTodoErrorMessage = null;
		delegateTodoErrorMessage = null;
		delegateTodoSuccessMessage = null;

		var title = newTodoTitle.Trim();

		if (string.IsNullOrWhiteSpace(title))
		{
			addTodoErrorMessage = "Enter a title before adding a to-do item.";
			return;
		}

		isSubmittingTodo = true;
		AddTodoApiResult addResult;

		if (selectedAddTodoKind == AddTodoKind.ChangeOmega)
		{
			addResult = await AddChangeOmegaTodoAsync(title);
		}
		else
		{
			addResult = await ApiClient.AddTodoAsync(title);
		}

		isSubmittingTodo = false;

		if (!string.IsNullOrWhiteSpace(addResult.ErrorMessage))
		{
			addTodoErrorMessage = addResult.ErrorMessage;
			return;
		}

		newTodoTitle = string.Empty;
		await LoadTodosAsync();
	}

	private async Task<AddTodoApiResult> AddChangeOmegaTodoAsync(string parentTitle)
	{
		var parentResult = await ApiClient.AddTodoAsync(parentTitle);

		if (!string.IsNullOrWhiteSpace(parentResult.ErrorMessage) || parentResult.Todo is null)
		{
			return AddTodoApiResult.Failure(parentResult.ErrorMessage ?? "Failed to create Change Omega to-do.");
		}

		foreach (var childTitle in ChangeOmegaChildTodoTitles)
		{
			var childResult = await ApiClient.AddTodoAsync(childTitle, parentResult.Todo.Id);

			if (!string.IsNullOrWhiteSpace(childResult.ErrorMessage))
			{
				return AddTodoApiResult.Failure($"Created parent to-do but failed to add child '{childTitle}': {childResult.ErrorMessage}");
			}
		}

		return AddTodoApiResult.Success(parentResult.Todo);
	}

	private string GetAddTodoPlaceholder() => selectedAddTodoKind switch
	{
		AddTodoKind.ChangeOmega => "Describe the change to make in Omega",
		_ => "Add a new to-do"
	};

	private async Task HandleToggleTodoAsync(TodoItem todo)
	{
		toggleTodoErrorMessage = null;
		deleteTodoErrorMessage = null;
		moveTodoErrorMessage = null;
		delegateTodoErrorMessage = null;
		delegateTodoSuccessMessage = null;
		togglingTodoIds.Add(todo.Id);

		var result = await ApiClient.SetTodoCompletionAsync(todo.Id, !todo.IsComplete);

		togglingTodoIds.Remove(todo.Id);

		if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
		{
			toggleTodoErrorMessage = result.ErrorMessage;
			return;
		}

		await LoadTodosAsync();
	}

	private void HandleStartAddChild(TodoItem todo)
	{
		addTodoErrorMessage = null;
		addingChildParentId = todo.Id;
		addingChildTitle = string.Empty;
	}

	private void CancelAddChild()
	{
		addingChildParentId = null;
		addingChildTitle = string.Empty;
	}

	private async Task HandleSaveAddChildAsync(TodoItem parentTodo)
	{
		addTodoErrorMessage = null;
		toggleTodoErrorMessage = null;
		deleteTodoErrorMessage = null;
		moveTodoErrorMessage = null;
		delegateTodoErrorMessage = null;
		delegateTodoSuccessMessage = null;

		if (addingChildParentId != parentTodo.Id)
		{
			addTodoErrorMessage = "Select a parent to-do before adding a child.";
			return;
		}

		var title = addingChildTitle.Trim();

		if (string.IsNullOrWhiteSpace(title))
		{
			addTodoErrorMessage = "Enter a title before adding a child to-do item.";
			return;
		}

		isSubmittingTodo = true;
		var result = await ApiClient.AddTodoAsync(title, parentTodo.Id);
		isSubmittingTodo = false;

		if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
		{
			addTodoErrorMessage = result.ErrorMessage;
			return;
		}

		CancelAddChild();
		await LoadTodosAsync();
	}

	private async Task HandleAddChildKeydownAsync(KeyboardEventArgs e, TodoItem parentTodo)
	{
		if (e.Key == "Enter")
		{
			await HandleSaveAddChildAsync(parentTodo);
		}
		else if (e.Key == "Escape")
		{
			CancelAddChild();
		}
	}

	private void HandleDeleteTodoAsync(TodoItem todo)
	{
		deleteTodoErrorMessage = null;
		toggleTodoErrorMessage = null;
		moveTodoErrorMessage = null;
		delegateTodoErrorMessage = null;
		delegateTodoSuccessMessage = null;
		pendingDeleteTodo = todo;
	}

	private async Task HandleMoveTodoAsync(TodoItem todo, bool moveUp)
	{
		moveTodoErrorMessage = null;
		deleteTodoErrorMessage = null;
		toggleTodoErrorMessage = null;
		delegateTodoErrorMessage = null;
		delegateTodoSuccessMessage = null;
		movingTodoIds.Add(todo.Id);

		var result = await ApiClient.MoveTodoAsync(todo.Id, moveUp);

		movingTodoIds.Remove(todo.Id);

		if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
		{
			moveTodoErrorMessage = result.ErrorMessage;
			return;
		}

		await LoadTodosAsync();
	}

	private async Task HandleDelegateTodoAsync(TodoItem todo)
	{
		delegateTodoErrorMessage = null;
		delegateTodoSuccessMessage = null;
		moveTodoErrorMessage = null;
		deleteTodoErrorMessage = null;
		toggleTodoErrorMessage = null;
		delegatingTodoIds.Add(todo.Id);

		var result = await ApiClient.DelegateTodoAsync(todo.Id);

		delegatingTodoIds.Remove(todo.Id);

		if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
		{
			delegateTodoErrorMessage = result.ErrorMessage;
			return;
		}

		if (result.Response is not null)
		{
			delegateTodoSuccessMessage = $"Started AI agent process #{result.Response.ProcessId} for '{todo.Title}'.";
		}
		else
		{
			delegateTodoSuccessMessage = $"Delegated '{todo.Title}' to AI agent.";
		}
	}

	private void CancelDelete()
	{
		pendingDeleteTodo = null;
	}

	private async Task ConfirmDeleteAsync(bool promoteChildren)
	{
		var todo = pendingDeleteTodo!;
		pendingDeleteTodo = null;
		deletingTodoIds.Add(todo.Id);

		var result = await ApiClient.DeleteTodoAsync(todo.Id, promoteChildren);

		deletingTodoIds.Remove(todo.Id);

		if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
		{
			deleteTodoErrorMessage = result.ErrorMessage;
			return;
		}

		await LoadTodosAsync();
	}

	private async Task LoadTodosAsync()
	{
		isLoading = true;
		var result = await ApiClient.GetTodosAsync();
		todos = result.Todos;
		todoEntries = BuildTodoEntries(result.Todos);
		RefreshTodoSections(result.Todos, todoEntries);
		errorMessage = result.ErrorMessage;
		isLoading = false;
	}

	private void HandleStartEditAsync(TodoItem todo)
	{
		editingTodoId = todo.Id;
		editingTodoTitle = todo.Title;
	}

	private void CancelEdit()
	{
		editingTodoId = null;
		editingTodoTitle = string.Empty;
		pendingDeleteTodo = null;
		CancelAddChild();
	}

	private async Task HandleSaveEditAsync(TodoItem todo)
	{
		if (string.IsNullOrWhiteSpace(editingTodoTitle))
		{
			updateTodoErrorMessage = "Enter a title before saving.";
			return;
		}

		var trimmedTitle = editingTodoTitle.Trim();

		if (trimmedTitle == todo.Title)
		{
			CancelEdit();
			return;
		}

		updateTodoErrorMessage = null;
		deleteTodoErrorMessage = null;
		var result = await ApiClient.UpdateTodoTitleAsync(todo.Id, trimmedTitle);

		editingTodoId = null;
		editingTodoTitle = string.Empty;

		if (!string.IsNullOrWhiteSpace(result.ErrorMessage))
		{
			updateTodoErrorMessage = result.ErrorMessage;
			return;
		}

		await LoadTodosAsync();
	}

	private async Task HandleEditKeydownAsync(KeyboardEventArgs e, TodoItem todo)
	{
		if (e.Key == "Enter")
		{
			await HandleSaveEditAsync(todo);
		}
		else if (e.Key == "Escape")
		{
			CancelEdit();
		}
	}

	private static IReadOnlyList<TodoListEntry> BuildTodoEntries(IReadOnlyList<TodoItem> source)
	{
		var orderedEntries = new List<TodoListEntry>();
		AppendEntries(source, 0, null, 0, orderedEntries);
		return orderedEntries;
	}

	private static void AppendEntries(IReadOnlyList<TodoItem> source, int depth, int? parentId, int topLevelTodoId, ICollection<TodoListEntry> destination)
	{
		for (var i = 0; i < source.Count; i++)
		{
			var todo = source[i];
			var currentTopLevelTodoId = depth == 0 ? todo.Id : topLevelTodoId;
			destination.Add(new TodoListEntry(todo, depth, parentId, i, source.Count, currentTopLevelTodoId));

			if (todo.Children.Count > 0)
			{
				AppendEntries(todo.Children, depth + 1, todo.Id, currentTopLevelTodoId, destination);
			}
		}
	}

	private void RefreshTodoSections(IReadOnlyList<TodoItem> sourceTodos, IReadOnlyList<TodoListEntry> allEntries)
	{
		var completedTopLevelTodos = sourceTodos
			.Where(todo => todo.IsComplete)
			.ToArray();

		var completedTopLevelTodoIds = completedTopLevelTodos
			.Select(todo => todo.Id)
			.ToHashSet();

		activeTodoEntries = allEntries
			.Where(entry => !completedTopLevelTodoIds.Contains(entry.TopLevelTodoId))
			.ToArray();

		var entriesByTopLevelTodoId = allEntries
			.GroupBy(entry => entry.TopLevelTodoId)
			.ToDictionary(group => group.Key, group => (IReadOnlyList<TodoListEntry>)group.ToArray());

		completedTopLevelTodoGroups = completedTopLevelTodos
			.GroupBy(todo => todo.CompletedAt?.ToLocalTime().Date)
			.OrderByDescending(group => group.Key.HasValue)
			.ThenByDescending(group => group.Key)
			.Select(group =>
			{
				var orderedTopLevelTodos = group
					.OrderByDescending(todo => todo.CompletedAt.HasValue)
					.ThenByDescending(todo => todo.CompletedAt)
					.Select(todo => todo.Id)
					.ToArray();

				var groupedEntries = orderedTopLevelTodos
					.SelectMany(id => entriesByTopLevelTodoId.GetValueOrDefault(id) ?? [])
					.ToArray();

				return new CompletedTopLevelTodoGroup(group.Key, groupedEntries);
			})
			.ToArray();
	}

	private static string GetCompletedGroupHeading(DateTime? localCompletionDate) =>
		localCompletionDate is null
			? "Unknown completion date"
			: localCompletionDate.Value.ToString("D");

	private static string GetTodoIndentStyle(int depth) => $"padding-left: {1 + (depth * 2)}rem";

	private RenderFragment RenderTodoList(IReadOnlyList<TodoListEntry> entries) =>
	@<ul class="list-group">
		@foreach (var entry in entries)
		{
			var todo = entry.Todo;
			var canMoveUp = entry.SiblingIndex > 0;
			var canMoveDown = entry.SiblingIndex < entry.SiblingCount - 1;
			var isAddingChildForTodo = addingChildParentId == todo.Id;

			<li @key="todo.Id"
				class="list-group-item"
				style="@GetTodoIndentStyle(entry.Depth)">
				<div class="d-flex justify-content-between align-items-center gap-3">
					<div class="d-flex align-items-center gap-2 flex-wrap flex-grow-1">
						<input class="form-check-input mt-0"
							type="checkbox"
							checked="@todo.IsComplete"
							disabled="@(isSubmittingTodo || togglingTodoIds.Contains(todo.Id) || deletingTodoIds.Contains(todo.Id) || movingTodoIds.Contains(todo.Id) || editingTodoId == todo.Id)"
							@onchange="() => HandleToggleTodoAsync(todo)" />
						@if (editingTodoId == todo.Id)
						{
							<input class="form-control form-control-sm"
								type="text"
								value="@editingTodoTitle"
								disabled="@(isSubmittingTodo || togglingTodoIds.Contains(todo.Id) || deletingTodoIds.Contains(todo.Id) || movingTodoIds.Contains(todo.Id))"
								@onchange="(ChangeEventArgs e) => editingTodoTitle = e?.Value?.ToString() ?? string.Empty"
								@onkeydown="(KeyboardEventArgs e) => HandleEditKeydownAsync(e, todo)" />
						}
						else
						{
							<span>@todo.Title</span>
						}
						</div>

					<div class="d-flex gap-2">
						<button class="btn btn-sm btn-outline-primary"
								type="button"
								disabled="@(isSubmittingTodo || togglingTodoIds.Contains(todo.Id) || deletingTodoIds.Contains(todo.Id) || movingTodoIds.Contains(todo.Id) || delegatingTodoIds.Contains(todo.Id) || editingTodoId == todo.Id)"
								aria-label="Add child"
								@onclick="() => HandleStartAddChild(todo)">
							<i class="bi bi-plus-lg" aria-hidden="true"></i>
						</button>

						<button class="btn btn-sm btn-outline-info"
								type="button"
								disabled="@(isSubmittingTodo || togglingTodoIds.Contains(todo.Id) || deletingTodoIds.Contains(todo.Id) || movingTodoIds.Contains(todo.Id) || delegatingTodoIds.Contains(todo.Id) || editingTodoId == todo.Id)"
								aria-label="Delegate to AI"
								@onclick="() => HandleDelegateTodoAsync(todo)">
							@if (delegatingTodoIds.Contains(todo.Id))
							{
								<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
							}
							else
							{
								<i class="bi bi-robot" aria-hidden="true"></i>
							}
						</button>

						<button class="btn btn-sm btn-outline-secondary"
								type="button"
								disabled="@(isSubmittingTodo || togglingTodoIds.Contains(todo.Id) || deletingTodoIds.Contains(todo.Id) || movingTodoIds.Contains(todo.Id) || editingTodoId == todo.Id || !canMoveUp)"
								aria-label="Move up"
								@onclick="() => HandleMoveTodoAsync(todo, true)">
							<i class="bi bi-arrow-up" aria-hidden="true"></i>
						</button>
						<button class="btn btn-sm btn-outline-secondary"
								type="button"
								disabled="@(isSubmittingTodo || togglingTodoIds.Contains(todo.Id) || deletingTodoIds.Contains(todo.Id) || movingTodoIds.Contains(todo.Id) || editingTodoId == todo.Id || !canMoveDown)"
								aria-label="Move down"
								@onclick="() => HandleMoveTodoAsync(todo, false)">
							<i class="bi bi-arrow-down" aria-hidden="true"></i>
						</button>

						@if (editingTodoId == todo.Id)
						{
							<button class="btn btn-sm btn-success"
									type="button"
									disabled="@(isSubmittingTodo || togglingTodoIds.Contains(todo.Id) || deletingTodoIds.Contains(todo.Id) || movingTodoIds.Contains(todo.Id))"
									aria-label="Save"
									@onclick="() => HandleSaveEditAsync(todo)">
								<i class="bi bi-check" aria-hidden="true"></i>
							</button>
							<button class="btn btn-sm btn-secondary"
									type="button"
									disabled="@(isSubmittingTodo || togglingTodoIds.Contains(todo.Id) || deletingTodoIds.Contains(todo.Id) || movingTodoIds.Contains(todo.Id))"
									aria-label="Cancel"
									@onclick="CancelEdit">
								<i class="bi bi-x" aria-hidden="true"></i>
							</button>
						}
						else
						{
							<button class="btn btn-sm btn-outline-secondary"
									type="button"
									disabled="@(isSubmittingTodo || togglingTodoIds.Contains(todo.Id) || deletingTodoIds.Contains(todo.Id) || movingTodoIds.Contains(todo.Id))"
									aria-label="Edit"
									@onclick="() => HandleStartEditAsync(todo)">
								<i class="bi bi-pencil" aria-hidden="true"></i>
							</button>
						}

						<button class="btn btn-sm btn-outline-danger"
								type="button"
								disabled="@(isSubmittingTodo || togglingTodoIds.Contains(todo.Id) || deletingTodoIds.Contains(todo.Id) || movingTodoIds.Contains(todo.Id) || editingTodoId == todo.Id)"
								aria-label="Delete"
								@onclick="() => HandleDeleteTodoAsync(todo)">
							@if (deletingTodoIds.Contains(todo.Id))
							{
								<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
							}
							else
							{
								<i class="bi bi-trash" aria-hidden="true"></i>
							}
						</button>
					</div>
				</div>

				@if (isAddingChildForTodo)
				{
					<div class="d-flex gap-2 mt-2">
						<input class="form-control form-control-sm"
							type="text"
							value="@addingChildTitle"
							disabled="@isSubmittingTodo"
							placeholder="Add a child to-do"
							@onchange="(ChangeEventArgs e) => addingChildTitle = e?.Value?.ToString() ?? string.Empty"
							@onkeydown="(KeyboardEventArgs e) => HandleAddChildKeydownAsync(e, todo)" />
						<button class="btn btn-sm btn-success"
							type="button"
							disabled="@isSubmittingTodo"
							aria-label="Save child"
							@onclick="() => HandleSaveAddChildAsync(todo)">
							<i class="bi bi-check" aria-hidden="true"></i>
						</button>
						<button class="btn btn-sm btn-secondary"
							type="button"
							disabled="@isSubmittingTodo"
							aria-label="Cancel adding child"
							@onclick="CancelAddChild">
							<i class="bi bi-x" aria-hidden="true"></i>
						</button>
					</div>
				}
			</li>
		}
	</ul>;

	private enum AddTodoKind
	{
		StandardTodo,
		ChangeOmega
	}

	private sealed record TodoListEntry(TodoItem Todo, int Depth, int? ParentId, int SiblingIndex, int SiblingCount, int TopLevelTodoId);

	private sealed record CompletedTopLevelTodoGroup(DateTime? LocalCompletionDate, IReadOnlyList<TodoListEntry> Entries);
}
